common:release --copt=-O3
common:release --copt=-flto
common:release --linkopt=-flto
common:release --linkopt=-O3
common:release --linkopt=-pthread
common:release --linkopt=-lrt
common:release --@rules_rust//:extra_rustc_flags=-Cstrip=symbols
common:release --@rules_rust//:extra_rustc_flags=-Clto=true
common:release --@rules_rust//:extra_rustc_flags=-Ccodegen-units=1
common:release --@rules_rust//:extra_rustc_flags=-Cpanic=abort
common:release --@rules_rust//:extra_rustc_flags=-Copt-level=3